rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // Pairs are readable / writable by any authenticated user.
    // Tighten in production: e.g. only allow updates if request.auth.uid
    // matches babyUid or parentUid.
    match /pairs/{pairId} {
      allow read, create, update: if request.auth != null;

      // Events are append-only by an authenticated user.
      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
